# Hermes Web UI Monitor — production / default instance
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Blank values use the built-in defaults.
# The shell environment always wins over this file, so you can still pass
# one-off overrides at the command line.

# ── Core paths ────────────────────────────────────────────────────────────────

# Hermes home directory. All agent profiles, kanban DB, and logs are read
# from here. Default: ~/.hermes
HERMES_DIR=~/.hermes

# The default/root agent name — the one whose sessions live directly in
# HERMES_DIR rather than under HERMES_DIR/profiles/<name>.
# Default: sage
HERMES_ORCHESTRATOR=sage

# ── Monitor database ──────────────────────────────────────────────────────────

# SQLite file where the monitor stores API usage events and prompt traces.
# Default: <web-ui>/monitor.db
# Change this if you run two monitor instances so they don't share the same DB.
HERMES_MONITOR_DB=

# ── Web server ────────────────────────────────────────────────────────────────

# HTTP port the dashboard listens on.
# Default: 7979
HERMES_WEBUI_PORT=7979

# ── Agent gateway control ─────────────────────────────────────────────────────

# Set to the Docker container name if the Hermes gateway runs inside Docker.
# When set, the start/stop/restart buttons use `docker start/stop/restart`
# instead of launchctl. Leave blank for a native macOS launchd-managed gateway.
HERMES_DOCKER_CONTAINER=

# ── Extra home (side-by-side lab monitoring) ──────────────────────────────────

# Optional second Hermes home to monitor alongside the primary one.
# Used when you want to see both production agents and a Docker lab agent
# in the same dashboard (Option B). Leave blank for isolated monitoring.
# Example: /tmp/hermes-anton-lab/home
HERMES_EXTRA_HOME=

# ── Backup ────────────────────────────────────────────────────────────────────

# Git repo that contains backup.sh. The backup panel in the dashboard uses this.
# Leave blank to disable the backup panel.
HERMES_BACKUP_REPO=
HERMES_BACKUP_SCRIPT=

# ── Slack trace mirror ────────────────────────────────────────────────────────

# Mirror high-signal events (kanban milestones, errors) to a Slack channel.
# Both values must be set to enable. Tokens are read from HERMES_DIR/.env if
# not set here.
SLACK_BOT_TOKEN=
SLACK_TRACE_CHANNEL=

# Trace verbosity: "milestones" (default, quiet) or "verbose" (all tool calls).
HERMES_TRACE_MODE=milestones

# ── Startup feed warmup ───────────────────────────────────────────────────────

# How many seconds of past session events to replay into the activity feed on
# startup. Set to 0 to start with a clean feed.
# Default: 21600 (6 hours)
HERMES_WEBUI_WARMUP_FRESHNESS=21600

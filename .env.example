# Hermes Console
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Blank values use the built-in defaults.
# The shell environment always wins over this file.

# ── Core paths ────────────────────────────────────────────────────────────────

# Hermes home directory. All agent profiles, kanban DB, and logs are read
# from here. Point this at any Hermes install (native or Docker bind-mount).
# Default: ~/.hermes
HERMES_DIR=~/.hermes

# The default/root agent name — sessions live directly in HERMES_DIR rather
# than under HERMES_DIR/profiles/<name>. Default: sage
HERMES_ORCHESTRATOR=sage

# ── Console database ──────────────────────────────────────────────────────────

# SQLite file for API usage events and prompt traces.
# Default: <web-ui>/monitor.db
HERMES_MONITOR_DB=

# ── Web server ────────────────────────────────────────────────────────────────

# HTTP port and bind address for the dashboard.
HERMES_WEBUI_PORT=7979
HERMES_WEBUI_HOST=127.0.0.1

# ── Agent gateway control ─────────────────────────────────────────────────────

# Docker container name when gateways run inside Docker; blank = launchd.
HERMES_DOCKER_CONTAINER=

# Optional launchd mappings for native gateway control.
# Format: agent=/path/to/plist,other=/path/to/plist
HERMES_AGENT_PLISTS=

# Optional launchd labels for status checks.
# Format: agent=launchd.label,other=launchd.label
HERMES_AGENT_LABELS=

# ── Backup ────────────────────────────────────────────────────────────────────

# Git repo that contains backup.sh. Leave blank to hide the backup panel.
HERMES_BACKUP_REPO=
HERMES_BACKUP_SCRIPT=

# ── Slack trace mirror ────────────────────────────────────────────────────────

# Both values must be set to enable. Tokens are read from HERMES_DIR/.env if
# not set here.
SLACK_BOT_TOKEN=
SLACK_TRACE_CHANNEL=
HERMES_TRACE_MODE=milestones

# ── Generated media attribution ────────────────────────────────────────────────

# Optional media directory outside workspace/<agent>/output to scan for files.
HERMES_MEDIA_DIR=
HERMES_MEDIA_AGENT=imagine

# ── Startup feed warmup ───────────────────────────────────────────────────────

# Seconds of past session events to replay on startup. Default: 21600 (6 hours).
HERMES_WEBUI_WARMUP_FRESHNESS=21600

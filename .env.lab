# Hermes Web UI Monitor — Docker lab instance (Scenario A / Anton)

# ── Core ──────────────────────────────────────────────────────────────────────
HERMES_DIR=/tmp/hermes-anton-lab/home
HERMES_ORCHESTRATOR=sage
HERMES_WEBUI_PORT=7980

# ── Monitor database ──────────────────────────────────────────────────────────
HERMES_MONITOR_DB=/tmp/hermes-anton-lab/home/monitor.db

# ── Gateway control ───────────────────────────────────────────────────────────
HERMES_DOCKER_CONTAINER=hermes-anton-lab

# ── Backup ────────────────────────────────────────────────────────────────────
# Lab has no backup repo
HERMES_BACKUP_REPO=
HERMES_BACKUP_SCRIPT=

# ── Slack trace mirror ────────────────────────────────────────────────────────
# Set SLACK_BOT_TOKEN and SLACK_TRACE_CHANNEL to the Anton lab channel once
# #hermes-anton-lab is created and the bot is invited.
SLACK_BOT_TOKEN=
SLACK_TRACE_CHANNEL=
HERMES_TRACE_MODE=milestones

# ── Feed warmup ───────────────────────────────────────────────────────────────
HERMES_WEBUI_WARMUP_FRESHNESS=21600

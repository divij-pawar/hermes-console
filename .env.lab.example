# Hermes Web UI Monitor — Docker lab instance (Scenario A / Anton)
# Copy this file to .env.lab and fill in your values.
# start-lab.sh loads this file automatically before starting the monitor.
# The shell environment always wins over this file.

# ── Lab home ──────────────────────────────────────────────────────────────────

# Host-side path to the Docker container's bind-mounted Hermes home.
# This is /lab/home inside the container, exposed to the host via the volume
# mount defined in docker-compose.anton.yml.
HERMES_DIR=/tmp/hermes-anton-lab/home

# Root agent name inside the lab. Sage runs as the gateway inside the container.
HERMES_ORCHESTRATOR=sage

# ── Monitor database ──────────────────────────────────────────────────────────

# Separate monitor DB so lab usage events don't mix with production data.
HERMES_MONITOR_DB=/tmp/hermes-anton-lab/home/monitor.db

# ── Web server ────────────────────────────────────────────────────────────────

# Must differ from the production monitor port (default 7979).
HERMES_WEBUI_PORT=7980

# ── Docker container control ──────────────────────────────────────────────────

# Name of the running Anton lab container.
# Matches container_name in docker-compose.anton.yml.
HERMES_DOCKER_CONTAINER=hermes-anton-lab

# ── Backup ────────────────────────────────────────────────────────────────────

# Leave blank — the lab container has no backup repo.
HERMES_BACKUP_REPO=
HERMES_BACKUP_SCRIPT=

# ── Slack trace mirror ────────────────────────────────────────────────────────

# Optional: mirror Anton lab activity to a dedicated Slack channel.
# Set to the #hermes-anton-lab channel ID and bot token if desired.
SLACK_BOT_TOKEN=
SLACK_TRACE_CHANNEL=
HERMES_TRACE_MODE=milestones
